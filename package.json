{
  "name": "opencode-pty",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "version": "0.5.0",
  "description": "OpenCode plugin for interactive PTY management - run background processes, send input, read output with regex filtering",
  "author": "Eudritch",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "pty",
    "pseudo-terminal",
    "terminal",
    "background-process",
    "interactive",
    "cli",
    "shell",
    "dev-server",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eudritch/opencode-pty.git"
  },
  "bugs": {
    "url": "https://github.com/Eudritch/opencode-pty/issues"
  },
  "homepage": "https://github.com/Eudritch/opencode-pty#readme",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "default": "./dist/tui.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "unittest": "bun test",
    "test:all": "bun unittest",
    "build:plugin": "tsc -p tsconfig.build.json && bun x copyfiles -u 0 \"src/**/*.txt\" dist",
    "build:dev": "bun clean && bun build:plugin",
    "build:prod": "bun clean && bun build:plugin",
    "package:smoke": "bun test/packaged-native-daemon.ts",
    "tui:verify": "bun -e \"import('@opentui/solid/bun-plugin').then(({default:plugin}) => Bun.build({entrypoints:['tui.ts'],outdir:process.env.TEMP,target:'bun',plugins:[plugin]})).then(result => { if (!result.success) throw new Error('TUI build failed') })\"",
    "native:prepare": "bun scripts/prepare-native-artifact.ts",
    "native:manifest": "bun scripts/write-native-manifest.ts",
    "native:verify": "bun scripts/verify-native-artifacts.ts",
    "native:sign": "bun scripts/sign-native-artifacts.ts",
    "native:sign:windows": "bun scripts/sign-windows-worker.ts",
    "native:sign:macos": "bun scripts/sign-macos-worker.ts",
    "native:publish": "bun scripts/publish-native-artifacts.ts",
    "prepack": "bun build:prod",
    "clean": "rm -rf dist",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.8",
    "opencode": ">=1.3.13"
  },
  "dependencies": {
    "@opentui/core": "0.1.95",
    "@opentui/solid": "0.1.95",
    "@opencode-ai/plugin": "1.3.13",
    "@opencode-ai/sdk": "1.3.13",
    "solid-js": "1.9.11"
  },
  "optionalDependencies": {
    "@eudritch/opencode-pty-worker-darwin-arm64": "0.5.0",
    "@eudritch/opencode-pty-worker-darwin-x64": "0.5.0",
    "@eudritch/opencode-pty-worker-linux-arm64-gnu": "0.5.0",
    "@eudritch/opencode-pty-worker-linux-x64-gnu": "0.5.0",
    "@eudritch/opencode-pty-worker-win32-arm64": "0.5.0",
    "@eudritch/opencode-pty-worker-win32-x64": "0.5.0"
  }
}
